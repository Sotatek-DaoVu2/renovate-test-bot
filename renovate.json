{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["every 1 hour after 9am and before 6pm every weekday"],
  "timezone": "Asia/Singapore",
  "enabledManagers": ["docker-compose", "terraform", "custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Docker images in Terraform files",
      "fileMatch": ["\\.tf$"],
      "matchStrings": ["image\\s*=\\s*\"(?<depName>[^\"]+?):(?<currentValue>[^\"]+)\""],
      "datasourceTemplate": "docker"
    }
  ],
  "separateMinorPatch": true,
  "packageRules": [
    {
      "description": "Patch updates for Docker images",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["patch"],
      "automerge": false,
      "labels": ["dependencies", "docker", "patch"]
    },
    {
      "description": "Disable minor and major updates",
      "matchUpdateTypes": ["minor", "major"],
      "enabled": false
    },
    {
      "description": "Do not touch images using non-semver tags (main, latest, etc.)",
      "matchDatasources": ["docker"],
      "matchCurrentVersion": "/^(main|latest|main-latest)/",
      "enabled": false
    }
  ]
}
